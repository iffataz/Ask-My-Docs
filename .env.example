# LLM (Anthropic Claude) — used by the LangGraph pipeline (router/grade/rewrite/generate nodes)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Embeddings (OpenAI) — used by app/retrieval/embedder.py
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Vector store
CHROMA_PERSIST_DIR=./.chroma

# Chunking (app/ingestion/chunker.py)
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval / self-correcting graph
RETRIEVAL_K=5
MAX_REWRITES=2

# API
CORS_ORIGINS=["http://localhost:3000"]
LOG_JSON=false

# Frontend (frontend/lib/api.ts, frontend/lib/sse.ts)
NEXT_PUBLIC_API_URL=http://localhost:8000
